# Database (SQLite for dev, PostgreSQL for production)
DATABASE_URL="file:./dev.db"

# Redis (optional - uses in-memory for dev)
REDIS_URL="redis://localhost:6379"

# Auth
JWT_SECRET="change-me-to-a-random-256-bit-secret-in-production"
JWT_EXPIRY="24h"
REFRESH_TOKEN_EXPIRY_DAYS=30

# Admin Registration Code
ADMIN_REGISTER_CODE="ONEGROUP2025"

# MSG91 (OTP) - leave empty for dev mode (fixed OTP: 123456)
MSG91_AUTH_KEY=""
MSG91_TEMPLATE_ID=""
MSG91_SENDER_ID="ONEGRP"

# S3 / MinIO - leave empty for local file storage
S3_ENDPOINT=""
S3_REGION="us-east-1"
S3_BUCKET="onegroup-portal"
S3_ACCESS_KEY=""
S3_SECRET_KEY=""

# AI (PDF extraction)
GEMINI_API_KEY=""

# Email (Resend)
RESEND_API_KEY=""
RESEND_FROM="ONE Group <noreply@onegroup.in>"

# Scheduled jobs (payment escalation cron — generate a random 32+ char string)
CRON_SECRET=""

# WhatsApp
WHATSAPP_API_TOKEN=""

# Web Push (VAPID)
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Phase (controls which surfaces are exposed; valid values: TICKETS_ONLY, FULL)
NEXT_PUBLIC_PHASE="TICKETS_ONLY"

# Google Sign-In (leave empty to hide/disable the button)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
# Optional; defaults to `<origin>/api/auth/google/callback` if unset
GOOGLE_REDIRECT_URI=""
